local function HighlightLua(code)
    local keywords = {
        ["local"] = true, ["function"] = true, ["end"] = true, ["if"] = true,
        ["then"] = true, ["else"] = true, ["elseif"] = true, ["return"] = true,
        ["for"] = true, ["while"] = true, ["do"] = true, ["repeat"] = true,
        ["until"] = true, ["break"] = true, ["continue"] = true, ["in"] = true,
        ["and"] = true, ["or"] = true, ["not"] = true, ["true"] = true,
        ["false"] = true, ["nil"] = true
    }
    local globals = {
        ["game"] = true, ["workspace"] = true, ["script"] = true,
        ["print"] = true, ["warn"] = true, ["error"] = true,
        ["Vector2"] = true, ["Vector3"] = true, ["CFrame"] = true,
        ["Color3"] = true, ["UDim2"] = true, ["math"] = true,
        ["string"] = true, ["table"] = true, ["unpack"] = true
    }
    local output = ""
    local i = 1
    while i <= #code do
        local char = code:sub(i, i)
        if code:sub(i, i+1) == "--" then
            local endPos = code:find("\n", i) or #code + 1
            local comment = code:sub(i, endPos - 1)
            output = output .. '<font color="rgb(106, 153, 85)">' .. comment:gsub("<", "&lt;"):gsub(">", "&gt;") .. '</font>'
            i = endPos
        elseif char == '"' or char == "'" then
            local quote = char
            local endPos = i + 1
            local escaped = false
            while endPos <= #code do
                local c = code:sub(endPos, endPos)
                if escaped then
                    escaped = false
                elseif c == "\\" then
                    escaped = true
                elseif c == quote then
                    break
                end
                endPos = endPos + 1
            end
            local str = code:sub(i, endPos)
            output = output .. '<font color="rgb(206, 145, 120)">' .. str:gsub("<", "&lt;"):gsub(">", "&gt;") .. '</font>'
            i = endPos + 1
        elseif char:match("[%a_]") then
            local endPos = i
            while endPos <= #code and code:sub(endPos, endPos):match("[%w_]") do
                endPos = endPos + 1
            end
            local word = code:sub(i, endPos - 1)
            if keywords[word] then
                output = output .. '<font color="rgb(86, 156, 214)">' .. word .. '</font>'
            elseif globals[word] then
                output = output .. '<font color="rgb(78, 201, 176)">' .. word .. '</font>'
            else
                output = output .. word
            end
            i = endPos
        elseif char:match("%d") then
            local endPos = i
            while endPos <= #code and code:sub(endPos, endPos):match("[%d%.]") do
                endPos = endPos + 1
            end
            local num = code:sub(i, endPos - 1)
            output = output .. '<font color="rgb(181, 206, 168)">' .. num .. '</font>'
            i = endPos
        elseif char == ":" or char == "." then
            output = output .. char
            i = i + 1
            if i <= #code and code:sub(i, i):match("[%a_]") then
                local endPos = i
                while endPos <= #code and code:sub(endPos, endPos):match("[%w_]") do
                    endPos = endPos + 1
                end
                local method = code:sub(i, endPos - 1)
                output = output .. '<font color="rgb(220, 220, 170)">' .. method .. '</font>'
                i = endPos
            end
        else
            output = output .. char:gsub("<", "&lt;"):gsub(">", "&gt;")
            i = i + 1
        end
    end
    return output
end

local function GetPath(obj)
    if not obj or not obj.Parent then return "nil" end
    if obj == game then return "game" end
    if obj == workspace then return "workspace" end
    if obj.Parent == game then
        return 'game:GetService("' .. obj.ClassName .. '")'
    end
    local path = ""
    local current = obj
    while current.Parent and current ~= game do
        local name = current.Name
        if name:match("^[%a_][%w_]*$") then
            path = "." .. name .. path
        else
            path = '["' .. name:gsub('"', '\\"') .. '"]' .. path
        end
        current = current.Parent
    end
    if current == workspace then
        return "workspace" .. path
    else
        return "game" .. path
    end
end

local Serialize

local function Serialize(v, indent, visited)
    indent = indent or 0
    visited = visited or {}
    if v == nil then return "nil" end
    local t = typeof(v)
    if t == "string" then
        local result = {}
        table.insert(result, '"')
        for i = 1, #v do
            local byte = string.byte(v, i)
            local char = string.char(byte)
            if byte >= 32 and byte <= 126 then
                if char == '"' then table.insert(result, '\\"')
                elseif char == '\\' then table.insert(result, '\\\\')
                else table.insert(result, char) end
            else
                table.insert(result, "\\" .. byte)
            end
        end
        table.insert(result, '"')
        return table.concat(result)
    elseif t == "number" then
        if v == math.huge then return "math.huge" end
        if v == -math.huge then return "-math.huge" end
        return tostring(v)
    elseif t == "boolean" then
        return tostring(v)
    elseif t == "function" then
        return "nil --[[ Function ]]"
    elseif t == "userdata" then
        return "nil --[[ Userdata ]]"
    elseif t == "Instance" then
        return GetPath(v)
    elseif t == "EnumItem" then
        return tostring(v)
    elseif t == "Vector2" then
        return string.format("Vector2.new(%s, %s)", tostring(v.X), tostring(v.Y))
    elseif t == "Vector3" then
        return string.format("Vector3.new(%s, %s, %s)", tostring(v.X), tostring(v.Y), tostring(v.Z))
    elseif t == "Vector2int16" then
        return string.format("Vector2int16.new(%d, %d)", v.X, v.Y)
    elseif t == "Vector3int16" then
        return string.format("Vector3int16.new(%d, %d, %d)", v.X, v.Y, v.Z)
    elseif t == "CFrame" then
        return string.format("CFrame.new(%s)", tostring(v))
    elseif t == "UDim" then
        return string.format("UDim.new(%s, %s)", tostring(v.Scale), tostring(v.Offset))
    elseif t == "UDim2" then
        return string.format("UDim2.new(%s, %s, %s, %s)", tostring(v.X.Scale), tostring(v.X.Offset), tostring(v.Y.Scale), tostring(v.Y.Offset))
    elseif t == "Rect" then
        return string.format("Rect.new(%s, %s, %s, %s)", tostring(v.Min.X), tostring(v.Min.Y), tostring(v.Max.X), tostring(v.Max.Y))
    elseif t == "Color3" then
        return string.format("Color3.new(%s, %s, %s)", tostring(v.R), tostring(v.G), tostring(v.B))
    elseif t == "BrickColor" then
        return string.format("BrickColor.new(%q)", tostring(v))
    elseif t == "ColorSequence" then
        if #v.Keypoints > 2 then return "nil --[[ ColorSequence (Complex) ]]"
        else return string.format("ColorSequence.new(%s)", Serialize(v.Keypoints[1].Value, indent, visited)) end
    elseif t == "Ray" then
        return string.format("Ray.new(%s, %s)", Serialize(v.Origin, indent, visited), Serialize(v.Direction, indent, visited))
    elseif t == "NumberRange" then
        return string.format("NumberRange.new(%s, %s)", tostring(v.Min), tostring(v.Max))
    elseif t == "PhysicalProperties" then
        return string.format("PhysicalProperties.new(%s, %s, %s, %s, %s)",
            tostring(v.Density), tostring(v.Friction), tostring(v.Elasticity), tostring(v.FrictionWeight), tostring(v.ElasticityWeight))
    elseif t == "Faces" then
        local axes = {}
        if v.Top    then table.insert(axes, "Enum.NormalId.Top")    end
        if v.Bottom then table.insert(axes, "Enum.NormalId.Bottom") end
        if v.Left   then table.insert(axes, "Enum.NormalId.Left")   end
        if v.Right  then table.insert(axes, "Enum.NormalId.Right")  end
        if v.Back   then table.insert(axes, "Enum.NormalId.Back")   end
        if v.Front  then table.insert(axes, "Enum.NormalId.Front")  end
        return "Faces.new(" .. table.concat(axes, ", ") .. ")"
    elseif t == "table" then
        if visited[v] then
            return '"--[[ Cyclic Reference ]]"'
        end
        visited[v] = true
        local str = "{\n"
        local count = 0
        for _ in pairs(v) do count = count + 1 end
        if count == 0 then return "{}" end
        if v.n and type(v.n) == "number" then
            for i = 1, v.n do
                local val = v[i]
                local valStr = (val == nil) and "nil" or Serialize(val, indent + 1, visited)
                str = str .. string.rep("    ", indent + 1) .. "[" .. i .. "] = " .. valStr .. ",\n"
            end
        else
            for k, val in pairs(v) do
                local keyStr = ""
                if type(k) == "string" and k:match("^[%a_][%w_]*$") then
                    keyStr = k
                elseif type(k) == "string" then
                    keyStr = '["' .. k .. '"]'
                else
                    keyStr = "[" .. Serialize(k, 0, visited) .. "]"
                end
                str = str .. string.rep("    ", indent + 1) .. keyStr .. " = " .. Serialize(val, indent + 1, visited) .. ",\n"
            end
        end
        str = str .. string.rep("    ", indent) .. "}"
        return str
    end
    return "nil --[[ " .. t .. " ]]"
end

local function ConstructScript(name, path, argsStr, count, remoteType)
    local output = "-- Remote: " .. name .. "\n"
    output = output .. "-- Path: " .. path .. "\n"
    output = output .. "-- Type: " .. remoteType .. "\n"
    output = output .. "-- Args Count: " .. count .. "\n"
    output = output .. "local args = " .. argsStr .. "\n\n"
    local unpackCall = "unpack(args, 1, " .. count .. ")"
    if remoteType == "RemoteFunction" then
        output = output .. path .. ":InvokeServer(" .. unpackCall .. ")"
    elseif remoteType == "BindableEvent" then
        output = output .. path .. ":Fire(" .. unpackCall .. ")"
    elseif remoteType == "BindableFunction" then
        output = output .. path .. ":Invoke(" .. unpackCall .. ")"
    else
        output = output .. path .. ":FireServer(" .. unpackCall .. ")"
    end
    return output
end

local typeColors = {
    RemoteEvent           = Color3.fromRGB(230, 126, 34),
    RemoteFunction        = Color3.fromRGB(155, 89, 182),
    UnreliableRemoteEvent = Color3.fromRGB(241, 196, 15),
    OnClientEvent         = Color3.fromRGB(197, 134, 192),
    BindableEvent         = Color3.fromRGB(46, 204, 113),
    BindableFunction      = Color3.fromRGB(52, 152, 219),
}

local function AddLog(info)
    if not scanningEnabled then return end
    if blockedRemotes[info.Remote] then return end
    if excludedRemotes[info.Remote] then return end

    local remote     = info.Remote
    local remoteType = info.RemoteType or "RemoteEvent"
    local args       = info.Args or {}
    local hookType   = info.HookType or "outgoing"
    local callerScript = info.CallerScript

    local cachedPath = GetPath(remote)
    local cachedArgs = Serialize(args)
    local cachedName = remote.Name
    local argCount   = args.n or #args
    local timeStr    = os.date("%H:%M:%S")

    local matchedLog = nil
    for i = #logs, 1, -1 do
        local l = logs[i]
        if l.Remote == remote and l.CachedArgs == cachedArgs and l.HookType == hookType then
            matchedLog = l
            break
        end
    end

    if matchedLog then
        matchedLog.StackCount = matchedLog.StackCount + 1
        matchedLog.Time = timeStr
        logOrder = logOrder + 1
        matchedLog.Btn.LayoutOrder = -logOrder
        local callerTxt = matchedLog.CallerScript and ("  " .. tostring(matchedLog.CallerScript)) or ""
        matchedLog.InfoLabel.Text = timeStr .. "  •  " .. matchedLog.ArgCount .. " args" .. callerTxt .. "  •  " .. matchedLog.StackCount .. "x"
        for i, l in ipairs(logs) do
            if l == matchedLog then
                table.remove(logs, i)
                break
            end
        end
        table.insert(logs, matchedLog)
        ScrollList.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
        updateStatus()
        return
    end

    local typeCount = 0
    local oldestIdx = nil
    for i, l in ipairs(logs) do
        if l.HookType == hookType then
            typeCount = typeCount + 1
            if oldestIdx == nil then oldestIdx = i end
        end
    end
    if typeCount >= MAX_LOGS and oldestIdx then
        local old = table.remove(logs, oldestIdx)
        if old.Btn then old.Btn:Destroy() end
    end

    local entry = {
        Remote      = remote,
        CachedName  = cachedName,
        CachedPath  = cachedPath,
        CachedArgs  = cachedArgs,
        CachedType  = remoteType,
        ArgCount    = argCount,
        Time        = timeStr,
        HookType    = hookType,
        CallerScript = callerScript,
        StackCount  = 1
    }

    logOrder = logOrder + 1

    local btn = Instance.new("TextButton")
    btn.Parent = ScrollList
    btn.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
    btn.Size = UDim2.new(1, -6, 0, 28)
    btn.Font = Enum.Font.GothamMedium
    btn.Text = ""
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.TextSize = 10
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ClipsDescendants = true
    btn.LayoutOrder = -logOrder

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 3)
    btnCorner.Parent = btn

    local typeColor = typeColors[remoteType] or Color3.fromRGB(149, 165, 166)

    local ind = Instance.new("Frame", btn)
    ind.Size = UDim2.new(0, 2, 1, 0)
    ind.BorderSizePixel = 0
    ind.BackgroundColor3 = typeColor

    local badge = Instance.new("TextLabel", btn)
    badge.Size = UDim2.new(0, 18, 0, 9)
    badge.Position = UDim2.new(1, -21, 0, 3)
    badge.BackgroundColor3 = hookType == "incoming" and Color3.fromRGB(120, 60, 160) or Color3.fromRGB(40, 60, 80)
    badge.TextColor3 = Color3.fromRGB(255, 255, 255)
    badge.Font = Enum.Font.GothamBold
    badge.TextSize = 6
    badge.Text = hookType == "incoming" and "IN" or "OUT"
    badge.BorderSizePixel = 0
    local badgeCorner = Instance.new("UICorner", badge)
    badgeCorner.CornerRadius = UDim.new(0, 2)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = btn
    nameLabel.BackgroundTransparency = 1
    nameLabel.Position = UDim2.new(0, 6, 0, 1)
    nameLabel.Size = UDim2.new(1, -28, 0, 14)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Text = cachedName
    nameLabel.TextColor3 = typeColor
    nameLabel.TextSize = 10
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd

    local infoLabel = Instance.new("TextLabel")
    infoLabel.Parent = btn
    infoLabel.BackgroundTransparency = 1
    infoLabel.Position = UDim2.new(0, 6, 0, 15)
    infoLabel.Size = UDim2.new(1, -28, 0, 11)
    infoLabel.Font = Enum.Font.Gotham
    infoLabel.TextColor3 = Color3.fromRGB(130, 130, 130)
    infoLabel.TextSize = 8
    infoLabel.TextXAlignment = Enum.TextXAlignment.Left
    infoLabel.TextTruncate = Enum.TextTruncate.AtEnd

    local callerTxt = callerScript and ("  " .. tostring(callerScript)) or ""
    infoLabel.Text = timeStr .. "  •  " .. argCount .. " args" .. callerTxt

    btn.MouseButton1Click:Connect(function()
        for _, l in pairs(logs) do
            if l.Btn then l.Btn.BackgroundColor3 = Color3.fromRGB(32, 32, 32) end
        end
        btn.BackgroundColor3 = Color3.fromRGB(44, 44, 44)
        selectedRemote = remote

        local out = ConstructScript(cachedName, cachedPath, cachedArgs, argCount, remoteType)
        if callerScript then
            out = "-- Called by: " .. tostring(callerScript) .. "\n" .. out
        end
        RawCodeBox.Text = out
        CodeBox.Text = HighlightLua(out)
    end)

    entry.Btn = btn
    entry.InfoLabel = infoLabel
    table.insert(logs, entry)
    ScrollList.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
    updateStatus()
    updateLogVisibility()
end

local function pack(...)
    return { n = select("#", ...), ... }
end

local function hookIncoming(remote)
    if incomingConnections[remote] then return end
    if not (remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent")) then return end
    incomingConnections[remote] = true
    pcall(function()
        remote.OnClientEvent:Connect(function(...)
            if not scanningEnabled then return end
            if blockedRemotes[remote] or excludedRemotes[remote] then return end
            AddLog({
                Remote = remote,
                RemoteType = "OnClientEvent",
                Args = pack(...),
                HookType = "incoming",
                CallerScript = nil,
            })
        end)
    end)
end

local function secureHookRemote(remote)
    if hookedRemotes[remote] then return end
    hookedRemotes[remote] = true

    if remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent") then
        local MyEvent = Instance.new("BindableEvent", game.CoreGui)
        MyEvent.Event:Connect(function(...)
            if blockedRemotes[remote] then return end
            local caller = nil
            pcall(function() caller = sigma.getcallingscript() end)
            AddLog({
                Remote = remote,
                RemoteType = remote.ClassName,
                Args = pack(...),
                HookType = "outgoing",
                CallerScript = caller,
            })
        end)
        pcall(function()
            sigma.rebounceevent(remote, "OnRemoteServerEvent", MyEvent)
        end)
        hookIncoming(remote)

    elseif remote:IsA("RemoteFunction") then
        local MyEvent = Instance.new("BindableEvent", game.CoreGui)
        MyEvent.Event:Connect(function(id, player, ...)
            if blockedRemotes[remote] then return end
            local caller = nil
            pcall(function() caller = sigma.getcallingscript() end)
            AddLog({
                Remote = remote,
                RemoteType = "RemoteFunction",
                Args = pack(...),
                HookType = "outgoing",
                CallerScript = caller,
            })
        end)
        pcall(function()
            sigma.rebounceevent(remote, "RemoteOnInvokeServer", MyEvent)
        end)
    end
end

for _, obj in game:GetDescendants() do
    if obj.Parent ~= game.RobloxReplicatedStorage then
        secureHookRemote(obj)
    end
end

game.DescendantAdded:Connect(function(obj)
    if obj.Parent ~= game.RobloxReplicatedStorage then
        secureHookRemote(obj)
    end
end)
