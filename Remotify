local function updateStatus()
    local excCount = 0
    local blkCount = 0
    local outCount = 0
    local inCount  = 0
    for _ in pairs(excludedRemotes) do excCount = excCount + 1 end
    for _ in pairs(blockedRemotes) do blkCount = blkCount + 1 end
    for _, l in ipairs(logs) do
        if l.HookType == "outgoing" then outCount = outCount + 1
        else inCount = inCount + 1 end
    end
    StatusLabel.Text = "Blocked: " .. blkCount
        .. "  |  Excluded: " .. excCount
        .. "  |  Out: " .. outCount
        .. "  |  In: " .. inCount
end

local function updateLogVisibility()
    local query = searchQuery:lower()
    for _, log in pairs(logs) do
        if log.Btn then
            local nameMatch = query == ""
                or log.CachedName:lower():find(query, 1, true)
                or log.CachedArgs:lower():find(query, 1, true)
            local filterMatch = (activeFilter == "Out" and log.HookType == "outgoing")
                or (activeFilter == "In"  and log.HookType == "incoming")
            log.Btn.Visible = nameMatch and filterMatch
        end
    end
    ScrollList.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
end

