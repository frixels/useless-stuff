	local propertiesMaid = Janitor.new()

	local function updateGuiProperties(object)
		propertiesMaid:Clean()
		for _, v in pairs(PropertiesScroll:GetChildren()) do 
			if not v:IsA("UIGridLayout") then v:Destroy() end 
		end

		if not object then return end

		local targetObjects = {}
		if MultiSelection[object] then
			for o, _ in pairs(MultiSelection) do table.insert(targetObjects, o) end
		else
			targetObjects = {object}
		end

		local function SetProperty(propName, value)
			for _, o in pairs(targetObjects) do
				pcall(function() o[propName] = value end)
			end
		end

		local aggregatedProps = {}
		local propCounters = {}
		local propValueMap = {}

		for _, obj in pairs(targetObjects) do
			local pList = GetProperties(obj)
			for _, p in pairs(pList) do
				local n = p.Name
				propCounters[n] = (propCounters[n] or 0) + 1

				if not propValueMap[n] then
					propValueMap[n] = {
						Val = p.RawValue,
						IsMixed = false,
						OrigClass = obj.ClassName
					}
				else
					if propValueMap[n].Val ~= p.RawValue then
						propValueMap[n].IsMixed = true
					end
				end
			end
		end

		local totalTargets = #targetObjects

		for name, info in pairs(propValueMap) do
			local category
			if propCounters[name] == totalTargets then
				category = "Common"
			else
				category = info.OrigClass
			end

			local displayVal = info.IsMixed and "..." or tostring(info.Val)
			if typeof(info.Val) == "Color3" and not info.IsMixed then
				displayVal = string.format("[%d, %d, %d]", info.Val.R*255, info.Val.G*255, info.Val.B*255)
			elseif typeof(info.Val) == "Vector3" and not info.IsMixed then
				displayVal = string.format("%.3f, %.3f, %.3f", info.Val.X, info.Val.Y, info.Val.Z)
			end

			table.insert(aggregatedProps, {
				ClassName = category,
				Name = name,
				Value = displayVal,
				RawValue = info.Val,
				IsMixed = info.IsMixed
			})
		end

		table.sort(aggregatedProps, function(a, b)
			if a.ClassName == "Common" and b.ClassName ~= "Common" then return true end
			if b.ClassName == "Common" and a.ClassName ~= "Common" then return false end
			if a.ClassName < b.ClassName then return true end
			if a.ClassName > b.ClassName then return false end
			return a.Name < b.Name
		end)

		local currentCategory = nil
		local layoutOrder = 0

		for _, v in pairs(aggregatedProps) do
			if v.ClassName ~= currentCategory then
				currentCategory = v.ClassName
				layoutOrder += 1

				local cat = Templates.GetPropCategory()
				cat.LayoutOrder = layoutOrder
				cat.Name = "Cat_" .. v.ClassName
				cat.Text.Text = v.ClassName
				cat.Parent = PropertiesScroll
				cat.Unpack.Rotation = 0

				-- FIX #1: Use v.ClassName directly instead of currentCategory in the closure
				local categoryName = v.ClassName
				propertiesMaid:Add(cat.Unpack.MouseButton1Click:Connect(function()
					local isExpanded = (cat.Unpack.Rotation == 0)
					cat.Unpack.Rotation = isExpanded and -90 or 0
					for _, child in pairs(PropertiesScroll:GetChildren()) do
						if child:GetAttribute("Category") == categoryName then
							child.Visible = not isExpanded
						end
					end
					updatePropertiesScroll()
				end))
			end

			layoutOrder += 1
			local pItem = Templates.GetPropItem()
			pItem.LayoutOrder = layoutOrder
			pItem.Name = "Prop_" .. v.Name
