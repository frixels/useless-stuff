	local function GetProperties(obj)
		if not obj then return {} end
		local props = {}

		local success, reflectedProps = pcall(function()
			return ReflectionService:GetPropertiesOfClass(obj.ClassName, {
				Security = allCapabilities, ExcludeInherited = false, ExcludeDisplay = false
			})
		end)

		if success and reflectedProps then
			for _, propDef in pairs(reflectedProps) do
				local rawVal = nil
				local readSuccess, result = pcall(function() return obj[propDef.Name] end)

				if readSuccess then
					rawVal = result
					local strValue = tostring(result)
					if typeof(result) == "Color3" then
						strValue = string.format("[%d, %d, %d]", result.R*255, result.G*255, result.B*255)
					elseif typeof(result) == "Vector3" then
						strValue = string.format("%.3f, %.3f, %.3f", result.X, result.Y, result.Z)
					end
					table.insert(props, {
						ClassName = "Properties", 
						Name = propDef.Name, 
						Value = strValue,
						RawValue = rawVal
					})
				end
			end
			table.sort(props, function(a,b) return a.Name < b.Name end)
			return props
		else
			return {{ClassName = "DexErr", Name = "Properties", Value = "Locked/Error", RawValue = nil}}
		end
	end

