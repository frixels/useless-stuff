local sheet = AssetService:CreateEditableImageAsync("rbxasset://textures/ClassImages.png")
local iconSize = sheet.Size.Y
local iconCache: {[number]: Content} = {}
local function getIconContent(index: number): Content
	if iconCache[index] then return iconCache[index] end

	local icon = AssetService:CreateEditableImage({ Size = Vector2.new(iconSize, iconSize) })
	icon:DrawImage(Vector2.new(-index * iconSize, 0), sheet, Enum.ImageCombineType.Overwrite)

	local content = Content.fromObject(icon)
	iconCache[index] = content
	return content
end



