	local function SetHighlight(obj)
		for _, h in ipairs(ExtraHighlights) do h:Destroy() end
		table.clear(ExtraHighlights)

		if not obj then
			SelectionBox.Adornee = nil
			return
		end

		if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("Model") then
			SelectionBox.Adornee = obj
			return
		end

		local adornees = {}
		local queue = {obj}
		local head = 1

		while head <= #queue do
			local current = queue[head]
			head += 1

			for _, child in ipairs(current:GetChildren()) do
				if child:IsA("Model") then
					table.insert(adornees, child)
				elseif child:IsA("BasePart") or child:IsA("MeshPart") then
					table.insert(adornees, child)
				else
					table.insert(queue, child)
				end
			end
		end

		if #adornees == 0 then
			SelectionBox.Adornee = nil
			return
		end

		SelectionBox.Adornee = adornees[1]
		for i = 2, #adornees do
			local h = Instance.new("Highlight")
			h.FillColor = SelectionBox.FillColor
			h.FillTransparency = SelectionBox.FillTransparency
			h.OutlineColor = SelectionBox.OutlineColor
			h.OutlineTransparency = SelectionBox.OutlineTransparency
			h.DepthMode = SelectionBox.DepthMode
			h.Adornee = adornees[i]
			h.Parent = ScreenGui
			table.insert(ExtraHighlights, h)
		end
	end

