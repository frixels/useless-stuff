local function numberToLetters(n)
	local result = ""

	while n > 0 do
		n -= 1
		local remainder = n % 26
		result = string.char(97 + remainder) .. result
		n = math.floor(n / 26)
	end

	return result
end

local function ParseVector3(text)
	local parts = string.split(text, ",")
	if #parts == 3 then
		return Vector3.new(tonumber(parts[1]) or 0, tonumber(parts[2]) or 0, tonumber(parts[3]) or 0)
	end
	return nil
end

