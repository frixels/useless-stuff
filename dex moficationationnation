local Janitor = {}
Janitor.__index = Janitor

function Janitor.new()
	return setmetatable({_objects = {}}, Janitor)
end

function Janitor:Add(object, methodName)
	if object then
		methodName = methodName or "Disconnect"
		table.insert(self._objects, {object, methodName})
	end
	return object
end

function Janitor:Clean()
	for i = #self._objects, 1, -1 do
		local objData = self._objects[i]
		local obj = objData[1]
		local method = objData[2]
		if type(obj) == "function" then
			obj()
		elseif typeof(obj) == "RBXScriptConnection" then
			obj:Disconnect()
		elseif obj[method] then
			obj[method](obj)
		end
		self._objects[i] = nil
	end
end

function Janitor:Destroy()
	self:Clean()
	self._objects = nil
end

