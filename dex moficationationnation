				inputUI.BackgroundTransparency = 1
				inputUI.Text = v.IsMixed and "..." or v.Value
				inputUI.TextColor3 = Theme.TextDim
				inputUI.Font = Enum.Font.Gotham
				inputUI.TextSize = 12
				inputUI.TextXAlignment = Enum.TextXAlignment.Left
				inputUI.Parent = pItem
			end
		end

		local attrList = {}
		for _, obj in pairs(targetObjects) do
			local success, attrs = pcall(function() return obj:GetAttributes() end)
			if success and attrs then
				for attrName, attrValue in pairs(attrs) do
					if not attrList[attrName] then
						attrList[attrName] = {
							Val = attrValue,
							IsMixed = false
						}
					else
						if attrList[attrName].Val ~= attrValue then
							attrList[attrName].IsMixed = true
						end
					end
				end
			end
		end

		local hasAttributes = false
		for _ in pairs(attrList) do hasAttributes = true break end

		if hasAttributes then
			local attrCategory = Templates.GetPropCategory()
			attrCategory.Name = "Cat_Attributes"
			attrCategory.Text.Text = "  ATTRIBUTES"
			attrCategory.LayoutOrder = 9999
			attrCategory.Parent = PropertiesScroll

			propertiesMaid:Add(attrCategory.Unpack.MouseButton1Click:Connect(function()
				if attrCategory.Unpack.Rotation == -90 then
					attrCategory.Unpack.Rotation = 0
					for _, child in pairs(PropertiesScroll:GetChildren()) do
						if child:IsA("Frame") and child:GetAttribute("Category") == "Attributes" then
							child.Visible = true
						end
					end
				else
					attrCategory.Unpack.Rotation = -90
					for _, child in pairs(PropertiesScroll:GetChildren()) do
						if child:IsA("Frame") and child:GetAttribute("Category") == "Attributes" then
							child.Visible = false
						end
					end
				end
				updatePropertiesScroll()
			end))

			local sortedAttrs = {}
			for name, data in pairs(attrList) do
				table.insert(sortedAttrs, {Name = name, Data = data})
			end
			table.sort(sortedAttrs, function(a, b) return a.Name < b.Name end)

			for _, attrInfo in ipairs(sortedAttrs) do
				local attrName = attrInfo.Name
				local attrData = attrInfo.Data

				local pItem = Templates.GetPropItem()
				pItem.Name = "Prop_" .. attrName
				pItem:SetAttribute("Category", "Attributes")
				pItem.LayoutOrder = 9999 + _ 
				pItem.Parent = PropertiesScroll
				pItem.Visible = true

				local overName = pItem.OverName
				overName.Text = "  " .. attrName
				overName.TextColor3 = Color3.fromRGB(255, 200, 100)

				local valType = typeof(attrData.Val)
				local inputUI

				if valType == "boolean" then
					inputUI = Instance.new("TextButton")
					inputUI.Size = UDim2.new(0.6, -5, 1, -4)
					inputUI.Position = UDim2.new(0.4, 2, 0, 2)
					inputUI.BackgroundColor3 = Theme.MainBG
					inputUI.BorderColor3 = Theme.Border
					if attrData.IsMixed then
						inputUI.Text = "  <Mixed>"
						inputUI.TextColor3 = Theme.TextDim
					else
						inputUI.Text = "  " .. tostring(attrData.Val)
						inputUI.TextColor3 = attrData.Val and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(200, 100, 100)
					end
					inputUI.Font = Enum.Font.Gotham
					inputUI.TextSize = 12
					inputUI.TextXAlignment = Enum.TextXAlignment.Left
					inputUI.Parent = pItem

					propertiesMaid:Add(inputUI.MouseButton1Click:Connect(function()
						local newVal = not (attrData.IsMixed and true or attrData.Val)
						for _, obj in pairs(targetObjects) do
							pcall(function() obj:SetAttribute(attrName, newVal) end)
						end
						inputUI.Text = "  " .. tostring(newVal)
						inputUI.TextColor3 = newVal and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(200, 100, 100)
					end))

					for _, obj in pairs(targetObjects) do
						local success, sig = pcall(function()
							return obj:GetAttributeChangedSignal(attrName)
						end)
						if success and sig then
							propertiesMaid:Add(sig:Connect(function()
								local firstVal = nil
								local allSame = true
								for _, o in pairs(targetObjects) do
									local success, val = pcall(function() return o:GetAttribute(attrName) end)
									if success then
										if firstVal == nil then
											firstVal = val
										elseif firstVal ~= val then
											allSame = false
											break
										end
									end
								end

								if allSame and firstVal ~= nil then
									inputUI.Text = "  " .. tostring(firstVal)
									inputUI.TextColor3 = firstVal and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(200, 100, 100)
								else
									inputUI.Text = "  <Mixed>"
									inputUI.TextColor3 = Theme.TextDim
								end
							end))
						end
					end

				elseif valType == "number" then
					inputUI = Instance.new("TextBox")
					inputUI.Size = UDim2.new(0.6, -5, 1, 0)
					inputUI.Position = UDim2.new(0.4, 2, 0, 0)
					inputUI.BackgroundTransparency = 1
					inputUI.Text = attrData.IsMixed and "" or tostring(attrData.Val)
					inputUI.PlaceholderText = attrData.IsMixed and "..." or ""
					inputUI.TextColor3 = Color3.fromRGB(255, 200, 100)
					inputUI.Font = Enum.Font.Gotham
					inputUI.TextSize = 12
					inputUI.TextXAlignment = Enum.TextXAlignment.Left
					inputUI.ClearTextOnFocus = false
					inputUI.Parent = pItem

					propertiesMaid:Add(inputUI.FocusLost:Connect(function(enter)
						if enter then
							local num = tonumber(inputUI.Text)
							if num then
								for _, obj in pairs(targetObjects) do
									pcall(function() obj:SetAttribute(attrName, num) end)
								end
							end
						end
					end))

					for _, obj in pairs(targetObjects) do
						local success, sig = pcall(function()
							return obj:GetAttributeChangedSignal(attrName)
						end)
						if success and sig then
							propertiesMaid:Add(sig:Connect(function()
								local firstVal = nil
								local allSame = true
								for _, o in pairs(targetObjects) do
									local success, val = pcall(function() return o:GetAttribute(attrName) end)
									if success then
										if firstVal == nil then
											firstVal = val
										elseif firstVal ~= val then
											allSame = false
											break
										end
									end
								end

								if allSame and firstVal ~= nil then
									inputUI.Text = tostring(firstVal)
									inputUI.PlaceholderText = ""
								else
									inputUI.Text = ""
									inputUI.PlaceholderText = "..."
								end
							end))
						end
					end

				elseif valType == "string" or valType == "Vector3" or valType == "Vector2" or valType == "Color3" or valType == "UDim2" then
					inputUI = Instance.new("TextBox")
					inputUI.Size = UDim2.new(0.6, -5, 1, 0)
					inputUI.Position = UDim2.new(0.4, 2, 0, 0)
					inputUI.BackgroundTransparency = 1

					local displayText = ""
					if not attrData.IsMixed then
						if valType == "Vector3" then
							displayText = string.format("%.3f, %.3f, %.3f", attrData.Val.X, attrData.Val.Y, attrData.Val.Z)
						elseif valType == "Vector2" then
							displayText = string.format("%.3f, %.3f", attrData.Val.X, attrData.Val.Y)
						elseif valType == "Color3" then
							displayText = string.format("[%d, %d, %d]", attrData.Val.R*255, attrData.Val.G*255, attrData.Val.B*255)
						elseif valType == "UDim2" then
							displayText = string.format("{%.3f, %.3f}, {%.3f, %.3f}", attrData.Val.X.Scale, attrData.Val.X.Offset, attrData.Val.Y.Scale, attrData.Val.Y.Offset)
						else
							displayText = tostring(attrData.Val)
						end
					end

					inputUI.Text = attrData.IsMixed and "" or displayText
					inputUI.PlaceholderText = attrData.IsMixed and "..." or ""
					inputUI.TextColor3 = Theme.Accent
					inputUI.Font = Enum.Font.Gotham
					inputUI.TextSize = 12
					inputUI.TextXAlignment = Enum.TextXAlignment.Left
					inputUI.ClearTextOnFocus = false
					inputUI.Parent = pItem

					propertiesMaid:Add(inputUI.FocusLost:Connect(function(enter)
						if enter then
							local text = inputUI.Text
							if valType == "Vector3" then
								local vec = ParseVector3(text)
								if vec then
									for _, obj in pairs(targetObjects) do
										pcall(function() obj:SetAttribute(attrName, vec) end)
									end
								end
							elseif valType == "Vector2" then
								local x, y = text:match("([^,]+),%s*([^,]+)")
								if x and y then
									local vec = Vector2.new(tonumber(x) or 0, tonumber(y) or 0)
									for _, obj in pairs(targetObjects) do
										pcall(function() obj:SetAttribute(attrName, vec) end)
									end
								end
							elseif valType == "Color3" then
								local r, g, b = text:match("%[(%d+),%s*(%d+),%s*(%d+)%]")
								if r and g and b then
									local col = Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
									for _, obj in pairs(targetObjects) do
										pcall(function() obj:SetAttribute(attrName, col) end)
									end
								end
							else
								for _, obj in pairs(targetObjects) do
									pcall(function() obj:SetAttribute(attrName, text) end)
								end
							end
						end
					end))

					for _, obj in pairs(targetObjects) do
						local success, sig = pcall(function()
							return obj:GetAttributeChangedSignal(attrName)
						end)
						if success and sig then
							propertiesMaid:Add(sig:Connect(function()
								local firstVal = nil
								local allSame = true
								for _, o in pairs(targetObjects) do
									local success, val = pcall(function() return o:GetAttribute(attrName) end)
									if success then
										if firstVal == nil then
											firstVal = val
										elseif firstVal ~= val then
											allSame = false
											break
										end
									end
								end

								if allSame and firstVal ~= nil then
									local displayText = ""
									if typeof(firstVal) == "Vector3" then
										displayText = string.format("%.3f, %.3f, %.3f", firstVal.X, firstVal.Y, firstVal.Z)
									elseif typeof(firstVal) == "Vector2" then
										displayText = string.format("%.3f, %.3f", firstVal.X, firstVal.Y)
									elseif typeof(firstVal) == "Color3" then
										displayText = string.format("[%d, %d, %d]", firstVal.R*255, firstVal.G*255, firstVal.B*255)
									elseif typeof(firstVal) == "UDim2" then
										displayText = string.format("{%.3f, %.3f}, {%.3f, %.3f}", firstVal.X.Scale, firstVal.X.Offset, firstVal.Y.Scale, firstVal.Y.Offset)
									else
										displayText = tostring(firstVal)
									end
									inputUI.Text = displayText
									inputUI.PlaceholderText = ""
								else
									inputUI.Text = ""
									inputUI.PlaceholderText = "..."
								end
							end))
						end
					end
				else
					inputUI = Instance.new("TextLabel")
					inputUI.Size = UDim2.new(0.6, -5, 1, 0)
					inputUI.Position = UDim2.new(0.4, 2, 0, 0)
					inputUI.BackgroundTransparency = 1
					inputUI.Text = attrData.IsMixed and "..." or tostring(attrData.Val)
					inputUI.TextColor3 = Theme.TextDim
					inputUI.Font = Enum.Font.Gotham
					inputUI.TextSize = 12
					inputUI.TextXAlignment = Enum.TextXAlignment.Left
					inputUI.Parent = pItem
				end
			end
		end

		updatePropertiesScroll()
	end

	local function createNode(obj, offset, parentPrefix)
		if not obj then return end
		if NodeMap[obj] then return NodeMap[obj] end

		local maid = Janitor.new()
		local clone = Templates.GetExplorerItem()
		local sizeFrame = clone.Size_Frame
		local unpackBtn = sizeFrame.Unpack
		local isopen = sizeFrame.IsOpen
		local uniqueId = tostring(math.random(1e8, 1e9-1))
		local Name = numberToLetters(1e8-#obj:GetChildren())
		local thisPrefix
		if parentPrefix == "" then
			thisPrefix = "_" .. Name
		else
			thisPrefix = parentPrefix .. "_" .. Name
		end
		thisPrefix = thisPrefix .. "_" .. uniqueId
		clone.Name = thisPrefix

		sizeFrame.Nam.Text = tostring(obj.Name)
		sizeFrame.Position = UDim2.new(0, offset, 0, 0)
		sizeFrame.Insert.Position = UDim2.new(0, GetTextSize(sizeFrame.Nam).X + 45, 0.15, 0)
		displayClassIcon(sizeFrame.Type_Img, obj.ClassName)

		clone.Parent = ExplorerScroll

		local dataC = {Frame = clone, Maid = maid, Prefix = thisPrefix,VisibleChildren={},expand = function()
			isopen.Value = true
			unpackBtn.Rotation = 0
		end}
		NodeMap[obj] = dataC
		local VisibleChildren = dataC.VisibleChildren

		local function checkChildren()
			if #obj:GetChildren() > 0 then
				unpackBtn.Visible = true
			else
				unpackBtn.Visible = false
				unpackBtn.Rotation = -90
				isopen.Value = false
			end
		end
		local function cleanChildren(parentData)
			for child, data in parentData.VisibleChildren do
				data.Maid:Destroy()
				data.Frame:Destroy()
				NodeMap[child] = nil
				cleanChildren(data)
				parentData.VisibleChildren[child] = nil
			end
		end

		checkChildren()

		maid:Add(sizeFrame.Select.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				local startPos = input.Position
				local dragMaid = Janitor.new()

				local moved = false

				dragMaid:Add(UserInputService.InputChanged:Connect(function(moveInput)
					if moveInput.UserInputType == Enum.UserInputType.MouseMovement then
						local dist = (Vector2.new(moveInput.Position.X, moveInput.Position.Y) - Vector2.new(startPos.X, startPos.Y)).Magnitude
						if dist > 6 then
							moved = true
							if not DragSystem.IsDragging then
								DragSystem.IsDragging = true
								DragSystem.DraggingObj = obj

								local visual = dataC.Frame:Clone()
								visual.Size = UDim2.new(0, dataC.Frame.AbsoluteSize.X, 0, dataC.Frame.AbsoluteSize.Y)
								local sizeFrame = visual.Size_Frame
								sizeFrame.Position = UDim2.new(0, 0, 0, 0)
								sizeFrame.Insert.Visible = false
								local unpackBtn = sizeFrame.Unpack
								unpackBtn.Visible = false
								visual.Parent = ScreenGui
								DragSystem.VisualObj = visual
							end
						end
					end
				end))

				dragMaid:Add(UserInputService.InputEnded:Connect(function(endInput)
					if endInput.UserInputType == Enum.UserInputType.MouseButton1 then
						dragMaid:Destroy()

						if DragSystem.IsDragging then
							if DragSystem.TargetObj and DragSystem.DraggingObj and DragSystem.TargetObj ~= DragSystem.DraggingObj then

								local function SafeParent(child, newParent)
									local s, e = pcall(function()
										if not newParent:IsDescendantOf(child) then
											child.Parent = newParent
											local targetNode = NodeMap[newParent]
											if targetNode then targetNode.SetExpand(true) end
										end
									end)
									if not s then warn("Failed to parent:", e) end
								end

								if MultiSelection[DragSystem.DraggingObj] then
									for o, _ in pairs(MultiSelection) do
										SafeParent(o, DragSystem.TargetObj)
									end
								else
									SafeParent(DragSystem.DraggingObj, DragSystem.TargetObj)
								end
							end

							if DragSystem.VisualObj then DragSystem.VisualObj:Destroy() end
							DragSystem.IsDragging = false
							DragSystem.DraggingObj = nil
							DragSystem.VisualObj = nil
							DragSystem.TargetObj = nil

							return 
						end
					end
				end))
			end
		end))

		maid:Add(sizeFrame.MouseEnter:Connect(function()
			sizeFrame.Insert.Visible = true
			if not MultiSelection[obj] then sizeFrame.FastSelect.Visible = true end
			if DragSystem.IsDragging and DragSystem.DraggingObj ~= obj then
				DragSystem.TargetObj = obj

			end
		end))

		maid:Add(sizeFrame.MouseLeave:Connect(function()
			sizeFrame.Insert.Visible = false
			if not MultiSelection[obj] then sizeFrame.FastSelect.Visible = false end
			if DragSystem.IsDragging and DragSystem.TargetObj == obj then
				DragSystem.TargetObj = nil

			end
		end))

		maid:Add(sizeFrame.Select.MouseButton1Click:Connect(function()
			if InstanceSelectorState.Active then
				pcall(function()
					local targetObj = InstanceSelectorState.Object
					local propName = InstanceSelectorState.PropName

					if MultiSelection[targetObj] then
						for o, _ in pairs(MultiSelection) do
							pcall(function() o[propName] = obj end)
						end
					else
						pcall(function() targetObj[propName] = obj end)
					end
				end)
				InstanceSelectorState.Active = false
				InstanceSelectorState.Object = nil
				InstanceSelectorState.PropName = nil
				return
			end

			if DragSystem.IsDragging then return end

			local isCtrl = UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)
			local isShift = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.RightShift)

			if isShift and LastSelectionIndexObj and NodeMap[LastSelectionIndexObj] and LastSelectionIndexObj ~= obj then
				local children = ExplorerScroll:GetChildren()
				local frames = {}
				for _, v in pairs(children) do
					if v:IsA("Frame") and v.Visible then
						table.insert(frames, v)
					end
				end
				table.sort(frames, function(a,b) return a.Name < b.Name end)

				local startIdx, endIdx
				local name1 = NodeMap[LastSelectionIndexObj].Frame.Name
				local name2 = NodeMap[obj].Frame.Name

				for i, f in ipairs(frames) do
					if f.Name == name1 then startIdx = i end
					if f.Name == name2 then endIdx = i end
				end

				if startIdx and endIdx then
					if not isCtrl then ClearSelection() end

					local low = math.min(startIdx, endIdx)
					local high = math.max(startIdx, endIdx)

					local startName = frames[low].Name
					local endName = frames[high].Name

					for o, data in pairs(NodeMap) do
						if data.Frame.Visible and data.Frame.Name >= startName and data.Frame.Name <= endName then
							AddToSelection(o)
						end
					end
					updateGuiProperties(obj)
				end
			elseif isCtrl then
				if MultiSelection[obj] then
					RemoveFromSelection(obj)
					LastSelectionIndexObj = obj
				else
					AddToSelection(obj)
					LastSelectionIndexObj = obj
					selectedObject = obj
					SetHighlight(obj)
				end
				updateGuiProperties(obj)
			else
				ClearSelection()
				AddToSelection(obj)
				LastSelectionIndexObj = obj
				selectedObject = obj
				SetHighlight(obj)
				updateGuiProperties(obj)
			end

			PropertiesSearch.Text = ""
		end))


		maid:Add(sizeFrame.Select.MouseButton2Click:Connect(function() 
			if not MultiSelection[obj] then
				ClearSelection()
				AddToSelection(obj)
				LastSelectionIndexObj = obj
				selectedObject = obj
				SelectionBox.Adornee = obj
				updateGuiProperties(obj)
			end
			openContextMenu(obj) 
		end))

		maid:Add(sizeFrame.Insert.MouseButton1Click:Connect(function() displayInsertMenu(obj) end))

		local function toggleExpand()
			if not isopen.Value then
				unpackBtn.Rotation = 0
				isopen.Value = true
				local children = obj:GetChildren()
				for i, child in children do
					if not NodeMap[child] then
						VisibleChildren[child] = createNode(child, offset + 15, thisPrefix)
					end
				end
				updateExplorerScroll()
			else
				unpackBtn.Rotation = -90
				isopen.Value = false
				cleanChildren(dataC)
				updateExplorerScroll()
			end
		end
		local function SetExpand(val)
			if val then
				unpackBtn.Rotation = 0
				isopen.Value = true
				local children = obj:GetChildren()
				for i, child in children do
					if not NodeMap[child] then
						VisibleChildren[child] = createNode(child, offset + 15, thisPrefix)
					end
				end
				updateExplorerScroll()
			else
				unpackBtn.Rotation = -90
				isopen.Value = false
				cleanChildren(dataC)
				updateExplorerScroll()
			end
		end

		dataC.SetExpand = SetExpand

		maid:Add(unpackBtn.MouseButton1Click:Connect(toggleExpand))

		maid:Add(obj.ChildAdded:Connect(function(child)
			task.defer(function()
				if child.Parent ~= obj then 
					return 
				end
				checkChildren()
				if isopen.Value then
					if not NodeMap[child] then
						VisibleChildren[child] = createNode(child, offset + 15, thisPrefix)
						updateExplorerScroll()

					end
				end
			end)
		end))

		maid:Add(obj.ChildRemoved:Connect(function(child)
			checkChildren()
			VisibleChildren[child] = nil
		end))

		maid:Add(obj:GetPropertyChangedSignal("Name"):Connect(function()
			sizeFrame.Nam.Text = obj.Name
		end))

		maid:Add(obj.AncestryChanged:Connect(function(_, parent)
			if NodeMap[obj] then
				dataC.Maid:Destroy()
				dataC.Frame:Destroy()
				NodeMap[obj] = nil
				updateExplorerScroll()
			end
			if MultiSelection[obj] then
				RemoveFromSelection(obj)
			end
		end))


		return dataC
	end

	local function getParents(inst)
		local t = {}
		while inst do
			table.insert(t, 1, inst)
			inst = inst.Parent
		end
		return t
	end
	local function ClearTree()
		for obj,dataC in NodeMap do
			dataC.Maid:Destroy()
			dataC.Frame:Destroy()
			NodeMap[obj] = nil
		end
	end
	local function initTree()
		ClearTree()
		createNode(game, 0, "")
		updateExplorerScroll()
	end

	initTree()

	local isSearching = false
	ExplorerSearch.FocusLost:Connect(function(enter)
		if enter then
			local text = ExplorerSearch.Text
			if text == "" then
				if isSearching then isSearching = false initTree() end
				return
			end
			isSearching = true
			IsLoadingVal.Value = true
			ClearTree()

			task.spawn(function()
				local results = {}
				for i, v in game:GetDescendants() do
					if string.find(string.lower(v.Name), string.lower(text)) then table.insert(results, v) end
					if i % 1000 == 0 then RunService.RenderStepped:Wait() end
				end
				for i, v in results do
					local ParentNode = nil
					local prefix = ""
					local c = getParents(v)
					for i,v2 in c do
						if not NodeMap[v2] then
							local w = createNode(v2,(i-1)*15,prefix)
							if ParentNode then
								ParentNode.VisibleChildren[v2] = w
							end
						end
						if v2 ~= v then
							NodeMap[v2].expand()
						end
						prefix = NodeMap[v2].Prefix
						ParentNode = NodeMap[v2]
					end
					if i % 20 == 0 then RunService.RenderStepped:Wait() end
				end
				updateExplorerScroll()
				IsLoadingVal.Value = false
			end)
		end
	end)
end

StartLogic()
